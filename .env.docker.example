# ============================================
# Docker 部署环境变量模板
# ============================================
# 使用方法：
#   1. 复制此文件为 .env：
#      cp .env.docker.example .env
#   2. 修改下面的密码和密钥（至少改 MYSQL_ROOT_PASSWORD 和 JWT_SECRET）
#   3. 启动：
#      docker compose up -d --build

# ===== MySQL root 密码 =====
# 自己设一个强密码（16位以上，含大小写+数字+符号）
# 注意：改密码后旧数据会无法访问，首次部署后不要再改！
MYSQL_ROOT_PASSWORD=Gtr#2026!Docker&Db_88

# ===== JWT 密钥 =====
# 生成方法（在服务器或本地任意机器执行）：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# 或：
#   openssl rand -base64 48
# 把输出粘到下面
JWT_SECRET=please_generate_a_random_string_of_at_least_32_chars_xxxxxx

# ===== QQ 邮箱 SMTP（可选）=====
# 留空则使用 OTP_DEV_FIXED_CODE 固定验证码（开发模式）
# 上线时填入 QQ 邮箱 SMTP 凭据（SMTP_PASSWORD 用授权码而非登录密码），并把 OTP_DEV_FIXED_CODE 留空
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=重力隧道
SMTP_USE_TLS=true

# ===== OTP 开发模式固定验证码 =====
# ⚠️ 生产环境务必留空（删掉等号后面的值）！
# 否则任何人都能用此码登录任意邮箱！
# 本地/测试时设为 123456 方便调试
OTP_DEV_FIXED_CODE=123456

# ===== CORS 允许的来源 =====
# 改成你的服务器公网 IP + 端口（必须和 FRONTEND_PORT 一致）
# 如果有域名，改成 http://你的域名 或 https://你的域名
CORS_ORIGINS=http://你的服务器公网IP:8081

# ===== 前端访问端口 =====
# 默认 8081，避免和已有 Web 应用冲突
# 如果 80 端口空闲，改成 80 可以省略端口号（http://IP 而不是 http://IP:8081）
FRONTEND_PORT=8081
