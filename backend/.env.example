# ===== MySQL 数据库 =====
# 本地 MySQL 连接串，修改为你的用户名/密码/端口/库名
DATABASE_URL=mysql://root:[YOUR_PASSWORD]@127.0.0.1:3306/gravity_tunnel

# ===== 邮箱 SMTP（QQ 邮箱） =====
# 开发阶段可留空，OTP_DEV_FIXED_CODE 会生效（固定验证码 123456）
# 上线时填入 QQ 邮箱 SMTP 凭据（SMTP_PASSWORD 用授权码而非登录密码），并把 OTP_DEV_FIXED_CODE 留空
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=重力隧道
SMTP_USE_TLS=true

# ===== OTP 配置 =====
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_DEV_FIXED_CODE=123456

# ===== JWT =====
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=please_generate_a_random_string_of_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===== CORS =====
# 用逗号分隔多个源
CORS_ORIGINS=file://,http://localhost,http://127.0.0.1,http://localhost:5500,http://localhost:8080

# ===== 速率限制 =====
RATE_LIMIT_REGISTER=5/hour
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_SUBMIT_SCORE=30/minute
RATE_LIMIT_PROGRESS_SAVE=10/minute
RATE_LIMIT_CHALLENGE_CREATE=20/hour
# 账号管理增强限速
RATE_LIMIT_LOGIN_PASSWORD=10/minute
RATE_LIMIT_AVATAR_UPLOAD=5/minute
RATE_LIMIT_PASSWORD_CHANGE=5/minute
RATE_LIMIT_RESET_PASSWORD=3/hour
RATE_LIMIT_CHANGE_EMAIL=3/hour

# ===== 头像上传（可选，留空使用默认值） =====
# AVATAR_UPLOAD_DIR=uploads/avatars
# AVATAR_MAX_SIZE_BYTES=5242880
# AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/webp
# AVATAR_OUTPUT_SIZE=256

# ===== 密码规则（可选，留空使用默认值） =====
# PASSWORD_MIN_LENGTH=8
# PASSWORD_MAX_LENGTH=64

# ===== 应用 =====
APP_ENV=development
LOG_LEVEL=INFO
